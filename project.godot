; Engine configuration file.
; It's best edited using the editor and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section]
;   param=value

config_version=5

[application]

config/name="Hex Siege Arena"
config/description="Godot rebuild of Hex Siege Arena with AI-vs-AI as the flagship mode."
run/main_scene="res://scenes/boot/boot.tscn"
config/features=PackedStringArray("4.2", "Forward Plus")

[autoload]

AppState="*res://scripts/core/app_state.gd"
EventBus="*res://scripts/core/event_bus.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="forward_plus"
textures/vram_compression/import_etc2_astc=true
