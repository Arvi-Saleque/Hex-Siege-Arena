; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Hex Siege Arena"
config/description="Godot rebuild of Hex Siege Arena with AI-vs-AI as the flagship mode."
run/main_scene="res://scenes/boot/boot.tscn"
config/features=PackedStringArray("4.6", "Forward Plus")

[autoload]

AppState="*res://scripts/core/app_state.gd"
AudioManager="*res://scripts/core/audio_manager.gd"
EventBus="*res://scripts/core/event_bus.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

textures/vram_compression/import_etc2_astc=true
